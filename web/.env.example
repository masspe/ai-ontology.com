# Frontend env — copy to .env.local and fill in values. Never commit secrets.
# Leave VITE_AUTH_API_BASE empty to route /auth/* through the same-origin
# proxy (Vite dev server or reverse proxy). Override only when hitting the
# auth backend directly.
VITE_AUTH_API_BASE=
VITE_API_BASE=http://localhost:5000

# Public client IDs only (NEVER put client secrets in a frontend env)
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
