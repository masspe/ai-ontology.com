{
  "name": "ontology-web",
  "private": true,
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "author": "Winven AI Sarl, Route de Crassier 7, 1262 Eysins, VD, CH",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,auth,web -c blue,magenta,green \"npm:dev:server\" \"npm:dev:auth\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "cargo run --manifest-path ../Cargo.toml -p ontology-cli -- --data ../data serve --bind 127.0.0.1:5000",
    "dev:auth": "npm --prefix ../auth-server run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "reactflow": "^11.11.4",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
