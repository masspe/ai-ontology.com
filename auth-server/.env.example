# --- Server ---------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Frontend origin allowed by CORS (comma-separated for multiple)
WEB_ORIGIN=http://localhost:5173

# After OAuth completes, browser is redirected back here:
OAUTH_FRONTEND_CALLBACK=http://localhost:5173/oauth/callback

# --- Secrets (REQUIRED in production) -------------------------------------
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Random string used to sign the OAuth `state` cookie
OAUTH_STATE_SECRET=replace-me-with-another-random-string

# --- Google OAuth ---------------------------------------------------------
# Authorized redirect URI to configure in Google Cloud Console:
#   http://localhost:4000/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/oauth/google/callback

# --- Microsoft OAuth (Azure AD / Entra ID) --------------------------------
# Authorized redirect URI to configure in Azure portal:
#   http://localhost:4000/auth/oauth/microsoft/callback
# Use "common" tenant to allow personal + work accounts.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:4000/auth/oauth/microsoft/callback

# --- Storage --------------------------------------------------------------
# Path to JSON user store (dev only — swap for a real DB in prod).
USERS_FILE=./data/users.json
